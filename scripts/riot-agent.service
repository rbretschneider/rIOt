[Unit]
Description=rIOt Agent - Infrastructure Monitoring
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/riot-agent -config /etc/riot/agent.yaml
Restart=always
RestartSec=5
User=riot
Group=riot
SupplementaryGroups=docker systemd-journal
LimitNOFILE=65536

# Security hardening
ProtectSystem=strict
ReadWritePaths=/var/lib/riot /etc/riot /usr/local/bin/riot-agent
PrivateTmp=true

[Install]
WantedBy=multi-user.target
