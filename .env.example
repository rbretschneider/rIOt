# rIOt Server Configuration
# Copy to .env and edit values before running docker compose up

# Master API key — agents use this to register. Change this!
RIOT_API_KEY=changeme

# Dashboard login password. Change this!
RIOT_ADMIN_PASSWORD=changeme

# JWT secret for session tokens. If empty, auto-generated on each restart
# (which logs out all users). Set a random string for stable sessions.
RIOT_JWT_SECRET=

# PostgreSQL credentials
POSTGRES_USER=riot
POSTGRES_PASSWORD=riot
POSTGRES_DB=riot

# Days to keep telemetry snapshots (default: 30)
RIOT_RETENTION_DAYS=30

# CORS allowed origins (comma-separated). Leave empty for same-origin only.
# RIOT_ALLOWED_ORIGINS=https://riot.example.com

# TLS — uncomment to enable
# RIOT_TLS_DOMAIN=riot.example.com
# RIOT_TLS_CERT_DIR=/data/certs
